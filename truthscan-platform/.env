# TruthScan Backend — Environment Configuration
# Copy this to .env and fill in your values

# ── LLM / AI ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE
CLAUDE_MODEL=claude-sonnet-4-20250514

# ── External Search APIs (all optional but improve fact-check accuracy) ───────
NEWSAPI_KEY=YOUR_NEWSAPI_KEY
GOOGLE_FACT_CHECK_API_KEY=YOUR_GOOGLE_KEY
# SERPAPI_KEY=YOUR_SERPAPI_KEY        # optional

# ── Cache ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600
CACHE_TTL_FACT_CHECK=21600
CACHE_TTL_AI_DETECT=7200

# ── Vector DB ─────────────────────────────────────────────────────────────────
VECTOR_DB_PROVIDER=chroma
CHROMA_PERSIST_DIR=data/chroma_db
# PINECONE_API_KEY=YOUR_PINECONE_KEY  # optional cloud alternative

# ── Model Paths (after running scripts/setup_models.py --action export) ───────
EFFICIENTNET_MODEL_PATH=models/efficientnet_b4_ai_detector.onnx
XCEPTION_MODEL_PATH=models/xception_deepfake.onnx
CLIP_MODEL_NAME=openai/clip-vit-large-patch14

# ── Ensemble Weights (must sum to 1.0) ────────────────────────────────────────
ENSEMBLE_WEIGHT_EFFICIENTNET=0.35
ENSEMBLE_WEIGHT_XCEPTION=0.30
ENSEMBLE_WEIGHT_CLIP=0.20
ENSEMBLE_WEIGHT_FREQUENCY=0.15

# ── Thresholds ────────────────────────────────────────────────────────────────
AI_THRESHOLD_HIGH=0.75
AI_THRESHOLD_MID=0.40

# ── Server ────────────────────────────────────────────────────────────────────
ENV=production
DEBUG=false
ALLOWED_ORIGINS=["*"]
